# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# MongoDB Connection String
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Guild ID for local development (optional)
# Only used when .local_marker file exists
# Get from: Right-click your server in Discord (with Developer Mode enabled) → Copy Server ID
GUILD_ID=your_guild_id_here

# Spotify API Credentials
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Cloudflare R2 Storage Credentials
# Get from: https://dash.cloudflare.com/
ACCOUNT_ID=your_cloudflare_account_id_here
ACCESS_KEY_ID=your_cloudflare_access_key_id_here
SECRET_ACCESS_KEY=your_cloudflare_secret_access_key_here

# SubmitHub Labs API Key
# Get from: https://labs.submithub.com/
SH_LABS_APIKEY=your_submithub_api_key_here
